<%- include('partials/top', { today }) %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <div class="rounded-xl bg-[#000000] p-5 border border-slate-800">
    <div class="text-sm text-slate-400">This month income</div>
    <div class="text-3xl font-semibold mt-2"><%= formatCents(dash.incomeCents) %></div>
    <div class="text-xs text-slate-500 mt-1"><%= dash.monthStart %> to <%= dash.monthEnd %></div>
  </div>
  <div class="rounded-xl bg-slate-900 p-5 border border-slate-800">
    <div class="text-sm text-slate-400">This month expenses</div>
    <div class="text-3xl font-semibold mt-2"><%= formatCents(dash.expenseCents) %></div>
    <div class="text-xs text-slate-500 mt-1"><%= dash.monthStart %> to <%= dash.monthEnd %></div>
  </div>
  <div class="rounded-xl bg-slate-900 p-5 border border-slate-800">
    <div class="text-sm text-slate-400">Net</div>
    <div class="text-3xl font-semibold mt-2"><%= formatCents(dash.netCents) %></div>
    <div class="text-xs text-slate-500 mt-1">Income - expenses</div>
  </div>
</div>

<div class="mt-6 rounded-xl bg-slate-900 p-5 border border-slate-800">
  <div class="flex items-center justify-between gap-4">
    <div>
      <div class="font-semibold">Quick setup</div>
      <div class="text-xs text-slate-500 mt-1">Creates recurring Rent (monthly on the 1st) and Car Payment ($470, due in 14 days).</div>
    </div>
  </div>

  <form class="mt-4 flex flex-col md:flex-row gap-3" method="POST" action="/setup/defaults">
    <input name="rent_amount" placeholder="Rent amount (e.g. 1850)" class="flex-1 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <button class="px-3 py-2 rounded-lg bg-sky-300 text-slate-950 font-semibold hover:bg-sky-200" type="submit">Create / Update recurring</button>
  </form>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
  <div class="rounded-xl bg-slate-900 p-5 border border-slate-800">
    <div class="flex items-center justify-between">
      <div class="font-semibold">Goals</div>
      <a class="text-sm text-sky-300 hover:text-sky-200" href="/goals">Manage</a>
    </div>

    <% if (!dash.goals.length) { %>
      <div class="text-slate-400 text-sm mt-3">No goals yet. Add one (e.g. Car payoff).</div>
    <% } else { %>
      <div class="mt-4 space-y-3">
        <% dash.goals.forEach(g => { 
          const pct = g.target_cents ? Math.min(100, Math.round((g.current_cents / g.target_cents) * 100)) : 0;
        %>
          <div class="rounded-lg bg-slate-950/50 p-3 border border-slate-800">
            <div class="flex items-center justify-between gap-3">
              <div>
                <div class="font-medium"><%= g.name %></div>
                <div class="text-xs text-slate-400"><%= formatCents(g.current_cents) %> / <%= formatCents(g.target_cents) %> (<%= pct %>%)</div>
              </div>
              <div class="w-24">
                <div class="h-2 bg-slate-800 rounded-full overflow-hidden">
                  <div class="h-2 bg-emerald-500" <%- `style="width:${pct}%"` %>></div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="rounded-xl bg-slate-900 p-5 border border-slate-800">
    <div class="flex items-center justify-between">
      <div class="font-semibold">Upcoming recurring</div>
      <a class="text-sm text-sky-300 hover:text-sky-200" href="/recurring">Manage</a>
    </div>

    <% if (!dash.upcomingRecurring.length) { %>
      <div class="text-slate-400 text-sm mt-3">No recurring items yet. Add rent, subscriptions, etc.</div>
    <% } else { %>
      <div class="mt-4 space-y-3">
        <% dash.upcomingRecurring.forEach(r => { %>
          <div class="rounded-lg bg-slate-950/50 p-3 border border-slate-800">
            <div class="flex items-center justify-between">
              <div>
                <div class="font-medium"><%= r.name %></div>
                <div class="text-xs text-slate-400"><%= r.next_due_date %> • <%= r.type %> • <%= formatCents(r.amount_cents) %></div>
              </div>
              <div class="text-xs text-slate-500"><%= r.cadence %></div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<% if (budgetAlerts.length) { %>
<div class="mt-6 rounded-xl bg-slate-900 p-5 border border-slate-800">
  <div class="flex items-center justify-between">
    <div class="font-semibold">Budget alerts</div>
    <a class="text-sm text-sky-300 hover:text-sky-200" href="/budgets">Manage</a>
  </div>
  <div class="mt-4 space-y-2">
    <% budgetAlerts.forEach(b => { %>
      <div class="flex items-center justify-between rounded-lg bg-slate-950/50 p-3 border border-slate-800">
        <div>
          <span class="font-medium"><%= b.category %></span>
          <span class="text-xs text-slate-400 ml-2"><%= b.type %></span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm"><%= formatCents(b.spent) %> / <%= formatCents(b.monthly_limit_cents) %></span>
          <span class="text-xs font-semibold px-2 py-1 rounded <%= b.over ? 'bg-rose-500/20 text-rose-300' : 'bg-amber-500/20 text-amber-300' %>"><%= b.over ? 'OVER' : 'WARN' %> (<%= b.pct %>%)</span>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<% if (tripStats.trip_count > 0) { %>
<div class="mt-6 rounded-xl bg-slate-900 p-5 border border-slate-800">
  <div class="flex items-center justify-between">
    <div class="font-semibold">Trips & Mileage (this month)</div>
    <a class="text-sm text-sky-300 hover:text-sky-200" href="/trips">Manage</a>
  </div>
  <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-4">
    <div>
      <div class="text-xs text-slate-400">Trips</div>
      <div class="text-xl font-semibold mt-1"><%= tripStats.trip_count %></div>
    </div>
    <div>
      <div class="text-xs text-slate-400">Total miles</div>
      <div class="text-xl font-semibold mt-1"><%= tripStats.total_miles.toFixed(1) %></div>
    </div>
    <div>
      <div class="text-xs text-slate-400">Total cost</div>
      <div class="text-xl font-semibold mt-1"><%= formatCents(tripStats.totalCost) %></div>
      <div class="text-xs text-slate-500">Gas: <%= formatCents(tripStats.total_gas_cents) %> + Other: <%= formatCents(tripStats.total_other_cents) %></div>
    </div>
    <div>
      <div class="text-xs text-slate-400">Income earned</div>
      <div class="text-xl font-semibold mt-1 text-emerald-300"><%= formatCents(tripStats.total_income_cents) %></div>
    </div>
  </div>
  <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-4">
    <div>
      <div class="text-xs text-slate-400">Net profit</div>
      <div class="text-xl font-semibold mt-1 <%= tripStats.netProfit >= 0 ? 'text-emerald-300' : 'text-rose-300' %>"><%= formatCents(tripStats.netProfit) %></div>
    </div>
    <div>
      <div class="text-xs text-slate-400">Cost / mile</div>
      <div class="text-lg font-semibold mt-1"><%= formatCents(tripStats.costPerMile) %></div>
    </div>
    <div>
      <div class="text-xs text-slate-400">Profit / mile</div>
      <div class="text-lg font-semibold mt-1 <%= tripStats.profitPerMile >= 0 ? 'text-emerald-300' : 'text-rose-300' %>"><%= formatCents(tripStats.profitPerMile) %></div>
    </div>
    <div>
      <div class="text-xs text-slate-400">IRS deduction (<%= formatCents(IRS_MILEAGE_RATE_CENTS) %>/mi)</div>
      <div class="text-lg font-semibold mt-1"><%= formatCents(tripStats.irsDeduction) %></div>
    </div>
  </div>
  <div class="mt-4 p-3 rounded-lg border <%= tripStats.netProfit > 0 ? 'border-emerald-500/30 bg-emerald-500/10' : 'border-rose-500/30 bg-rose-500/10' %>">
    <span class="font-medium <%= tripStats.netProfit > 0 ? 'text-emerald-300' : 'text-rose-300' %>">
      <%= tripStats.netProfit > 0 ? 'Trips are profitable this month' : 'Trips are costing more than they earn' %>
    </span>
  </div>
</div>
<% } %>

<%- include('partials/bottom') %>
