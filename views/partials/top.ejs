<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DimeTrack</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-slate-950 text-slate-100">
    <div class="max-w-5xl mx-auto px-4 py-6">
      <div class="flex items-center justify-between gap-4 mb-6">
        <div>
          <div class="text-2xl font-semibold tracking-tight">DimeTrack</div>
          <div class="text-slate-400 text-sm">Track revenue, expenses, recurring bills, and payoff goals.</div>
        </div>
        <div class="text-sm text-slate-400">Today: <span class="text-slate-200"><%= today %></span></div>
      </div>

      <nav class="flex flex-wrap gap-2 mb-6">
        <a class="px-3 py-2 rounded-lg bg-slate-900 hover:bg-slate-800" href="/">Dashboard</a>
        <a class="px-3 py-2 rounded-lg bg-slate-900 hover:bg-slate-800" href="/transactions">Transactions</a>
        <a class="px-3 py-2 rounded-lg bg-slate-900 hover:bg-slate-800" href="/recurring">Recurring</a>
        <a class="px-3 py-2 rounded-lg bg-slate-900 hover:bg-slate-800" href="/goals">Goals</a>
      </nav>
