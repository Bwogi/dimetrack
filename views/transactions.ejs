<%- include('partials/top', { today }) %>

<div class="rounded-xl bg-[#000000] p-5 border border-slate-800">
  <div class="font-semibold">Add transaction</div>

  <form class="mt-4 grid grid-cols-1 md:grid-cols-6 gap-3" method="POST" action="/transactions">
    <select name="type" class="md:col-span-1 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800">
      <option value="income">income</option>
      <option value="expense">expense</option>
    </select>
    <input name="amount" placeholder="Amount (e.g. 1250.00)" class="md:col-span-1 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <input name="category" placeholder="Category (rent, salary, gas)" class="md:col-span-2 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <input name="date" type="date" value="<%= today %>" class="md:col-span-1 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" />
    <button class="md:col-span-1 px-3 py-2 rounded-lg bg-emerald-500 text-slate-950 font-semibold hover:bg-emerald-400" type="submit">Add</button>
    <input name="note" placeholder="Note (optional)" class="md:col-span-6 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" />
  </form>
</div>

<div class="mt-6 rounded-xl bg-slate-900 p-5 border border-slate-800">
  <div class="flex items-center justify-between">
    <div class="font-semibold">Recent transactions</div>
    <div class="flex items-center gap-3">
      <a class="text-xs px-3 py-2 rounded-lg bg-slate-950 border border-slate-800 hover:bg-slate-800" href="/reports/transactions.pdf">Download PDF</a>
      <div class="text-xs text-slate-500">Showing last <%= rows.length %></div>
    </div>
  </div>

  <div class="mt-4 overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="text-left text-slate-400">
          <th class="py-2 pr-4">Date</th>
          <th class="py-2 pr-4">Type</th>
          <th class="py-2 pr-4">Category</th>
          <th class="py-2 pr-4">Note</th>
          <th class="py-2 pr-4">Amount</th>
          <th class="py-2 pr-0"></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
          <tr class="border-t border-slate-800">
            <td class="py-2 pr-4 whitespace-nowrap"><%= r.date %></td>
            <td class="py-2 pr-4"><span class="px-2 py-1 rounded bg-slate-950 border border-slate-800"><%= r.type %></span></td>
            <td class="py-2 pr-4"><%= r.category %></td>
            <td class="py-2 pr-4 text-slate-400"><%= r.note || '' %></td>
            <td class="py-2 pr-4 font-medium <%= r.type === 'expense' ? 'text-rose-300' : 'text-emerald-300' %>">
              <%= r.type === 'expense' ? '-' : '+' %><%= formatCents(r.amount_cents) %>
            </td>
            <td class="py-2 pr-0">
              <form method="POST" action="/transactions/<%= r.id %>/delete" onsubmit="return confirm('Delete this transaction?')">
                <button class="text-xs px-2 py-1 rounded bg-slate-950 border border-slate-800 hover:bg-slate-800" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/bottom') %>
