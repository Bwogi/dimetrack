<%- include('partials/top', { today }) %>

<%
  let totMiles = 0, totGas = 0, totOther = 0, totIncome = 0;
  rows.forEach(t => { totMiles += t.miles; totGas += t.gas_cost_cents; totOther += t.other_cost_cents; totIncome += t.income_cents; });
  const totCost = totGas + totOther;
  const totNet = totIncome - totCost;
  const costPerMile = totMiles > 0 ? Math.round(totCost / totMiles) : 0;
  const profitPerMile = totMiles > 0 ? Math.round(totNet / totMiles) : 0;
  const irsDeduction = Math.round(totMiles * IRS_MILEAGE_RATE_CENTS);
%>

<% if (rows.length) { %>
<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
  <div class="rounded-xl bg-slate-900 p-4 border border-slate-800">
    <div class="text-xs text-slate-400">Trips</div>
    <div class="text-2xl font-semibold mt-1"><%= rows.length %></div>
    <div class="text-xs text-slate-500 mt-1"><%= totMiles.toFixed(1) %> miles total</div>
  </div>
  <div class="rounded-xl bg-slate-900 p-4 border border-slate-800">
    <div class="text-xs text-slate-400">Total cost</div>
    <div class="text-xl font-semibold text-rose-300 mt-1"><%= formatCents(totCost) %></div>
    <div class="text-xs text-slate-500 mt-1">Gas: <%= formatCents(totGas) %> + Other: <%= formatCents(totOther) %></div>
  </div>
  <div class="rounded-xl bg-slate-900 p-4 border border-slate-800">
    <div class="text-xs text-slate-400">Income earned</div>
    <div class="text-xl font-semibold text-emerald-300 mt-1"><%= formatCents(totIncome) %></div>
  </div>
  <div class="rounded-xl p-4 border <%= totNet >= 0 ? 'bg-emerald-500/10 border-emerald-500/30' : 'bg-rose-500/10 border-rose-500/30' %>">
    <div class="text-xs text-slate-400">Net profit</div>
    <div class="text-xl font-semibold mt-1 <%= totNet >= 0 ? 'text-emerald-300' : 'text-rose-300' %>"><%= formatCents(totNet) %></div>
    <div class="text-xs text-slate-500 mt-1"><%= formatCents(costPerMile) %>/mi cost · <%= formatCents(profitPerMile) %>/mi profit</div>
  </div>
  <div class="rounded-xl bg-slate-900 p-4 border border-slate-800">
    <div class="text-xs text-slate-400">IRS deduction</div>
    <div class="text-xl font-semibold text-sky-300 mt-1"><%= formatCents(irsDeduction) %></div>
    <div class="text-xs text-slate-500 mt-1">@ <%= formatCents(IRS_MILEAGE_RATE_CENTS) %>/mi × <%= totMiles.toFixed(1) %> mi</div>
  </div>
</div>

<% if (totNet !== 0) { %>
<div class="mb-6 p-4 rounded-xl border <%= totNet > 0 ? 'border-emerald-500/30 bg-emerald-500/10' : 'border-rose-500/30 bg-rose-500/10' %>">
  <div class="flex items-center gap-2">
    <span class="text-lg"><%= totNet > 0 ? '✓' : '✗' %></span>
    <span class="font-medium <%= totNet > 0 ? 'text-emerald-300' : 'text-rose-300' %>">
      <%= totNet > 0 ? 'Trips are profitable — earning more than they cost' : 'Trips are costing more than they earn' %>
    </span>
  </div>
</div>
<% } %>
<% } %>

<div class="rounded-xl bg-[#000000] p-5 border border-slate-800">
  <div class="flex items-center justify-between">
    <div class="font-semibold">Log trip</div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-slate-400">Vehicle: <%= vs.mpg %> MPG · gas <%= formatCents(vs.gas_price_cents) %>/gal</span>
    </div>
  </div>

  <form class="mt-4 grid grid-cols-1 md:grid-cols-4 gap-3" method="POST" action="/trips">
    <input name="destination" placeholder="Destination" class="md:col-span-2 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <input name="date" type="date" value="<%= today %>" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" />
    <div></div>
    <input name="odo_start" placeholder="Odometer start" type="number" step="0.1" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <input name="odo_end" placeholder="Odometer end" type="number" step="0.1" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <input name="gas_cost" placeholder="Gas cost (blank = auto)" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" />
    <input name="other_cost" placeholder="Other costs (0)" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" />
    <input name="income" placeholder="Income earned" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    <input name="note" placeholder="Note (optional)" class="px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" />
    <button class="px-3 py-2 rounded-lg bg-emerald-500 text-slate-950 font-semibold hover:bg-emerald-400" type="submit">Log trip</button>
    <a class="text-center px-3 py-2 rounded-lg bg-slate-900 border border-slate-800 hover:bg-slate-800 text-sm" href="/export/trips.csv">Export CSV</a>
  </form>
</div>

<div class="mt-4 rounded-xl bg-slate-900 p-5 border border-slate-800">
  <div class="flex items-center justify-between">
    <div class="font-semibold text-sm">Vehicle settings</div>
    <div class="text-xs text-slate-500">Used for auto gas cost estimation</div>
  </div>
  <form class="mt-3 flex flex-wrap gap-3 items-end" method="POST" action="/vehicle-settings">
    <div>
      <label class="text-xs text-slate-400 block mb-1">MPG</label>
      <input name="mpg" type="number" step="0.1" value="<%= vs.mpg %>" class="w-24 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    </div>
    <div>
      <label class="text-xs text-slate-400 block mb-1">Gas price ($/gal)</label>
      <input name="gas_price" value="<%= (vs.gas_price_cents / 100).toFixed(2) %>" class="w-28 px-3 py-2 rounded-lg bg-slate-950 border border-slate-800" required />
    </div>
    <button class="px-3 py-2 rounded-lg bg-sky-300 text-slate-950 font-semibold hover:bg-sky-200 text-sm" type="submit">Update</button>
  </form>
</div>

<div class="mt-6 rounded-xl bg-slate-900 p-5 border border-slate-800">
  <div class="flex items-center justify-between">
    <div class="font-semibold">Recent trips</div>
    <div class="text-xs text-slate-500">Showing last <%= rows.length %></div>
  </div>

  <% if (!rows.length) { %>
    <div class="text-slate-400 text-sm mt-3">No trips yet. Log one above.</div>
  <% } else { %>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="text-left text-slate-400">
            <th class="py-2 pr-3">Date</th>
            <th class="py-2 pr-3">Destination</th>
            <th class="py-2 pr-3">Miles</th>
            <th class="py-2 pr-3">Gas</th>
            <th class="py-2 pr-3">Other</th>
            <th class="py-2 pr-3">Income</th>
            <th class="py-2 pr-3">Net</th>
            <th class="py-2 pr-3">Odometer</th>
            <th class="py-2 pr-0"></th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(t => {
            const totalCost = t.gas_cost_cents + t.other_cost_cents;
            const net = t.income_cents - totalCost;
          %>
            <tr class="border-t border-slate-800">
              <td class="py-2 pr-3 whitespace-nowrap"><%= t.date %></td>
              <td class="py-2 pr-3 font-medium"><%= t.destination %></td>
              <td class="py-2 pr-3 text-amber-300 font-medium"><%= t.miles.toFixed(1) %></td>
              <td class="py-2 pr-3">
                <% if (t.gas_estimated) { %>
                  <span class="text-slate-500" title="Auto-estimated">~<%= formatCents(t.gas_cost_cents) %></span>
                <% } else { %>
                  <span class="text-rose-300"><%= formatCents(t.gas_cost_cents) %></span>
                <% } %>
              </td>
              <td class="py-2 pr-3 text-slate-400"><%= formatCents(t.other_cost_cents) %></td>
              <td class="py-2 pr-3 text-emerald-300 font-medium"><%= formatCents(t.income_cents) %></td>
              <td class="py-2 pr-3 font-semibold <%= net >= 0 ? 'text-emerald-300' : 'text-rose-300' %>"><%= formatCents(net) %></td>
              <td class="py-2 pr-3 text-xs text-slate-500"><%= t.odometer_start != null ? t.odometer_start : '-' %> → <%= t.odometer_end != null ? t.odometer_end : '-' %></td>
              <td class="py-2 pr-0">
                <form method="POST" action="/trips/<%= t.id %>/delete" onsubmit="return confirm('Delete this trip?')">
                  <button class="text-xs px-2 py-1 rounded bg-slate-950 border border-slate-800 hover:bg-slate-800" type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/bottom') %>
